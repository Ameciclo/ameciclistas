# ==================== FIREBASE ====================
# Firebase Realtime Database URL
FIREBASE_DBURL=https://your-project.firebaseio.com

# Firebase Admin - chave privada (com \\n literais)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Admin - JSON completo da conta de serviço (private_key pode vir vazio, é substituído pelo FIREBASE_PRIVATE_KEY)
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account","project_id": "your-project","private_key_id": "","private_key": "","client_email": "firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com","client_id": "","auth_uri": "https://accounts.google.com/o/oauth2/auth","token_uri": "https://oauth2.googleapis.com/token","auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/xxxxx%40your-project.iam.gserviceaccount.com","universe_domain": "googleapis.com"}'

# ==================== AUTH / SESSIONS ====================
# Secret para os magic links de autenticação
MAGIC_LINK_SECRET=your-magic-link-secret

# Secret para sessões web
WEB_SESSION_SECRET=your-web-session-secret

# ==================== GOOGLE APIS ====================
# Google Service Account - email (deve estar no FIREBASE_SERVICE_ACCOUNT)
# GOOGLE_CLIENT_EMAIL=

# Google Service Account - chave privada
# GOOGLE_PRIVATE_KEY=

# Google Subject (impersonation) - email da conta a impersonar
GOOGLE_SUBJECT=user@your-org.com

# Dev Google Subject (para desenvolvimento local)
# DEV_GOOGLE_SUBJECT=

# ==================== CALENDARS ====================
# IDs dos calendários Google
# EXTERNAL_CALENDAR_ID=
# INTERNAL_CALENDAR_ID=
# ORG_CALENDAR_ID=
# PROMOTE_CALENDAR_ID=

# ==================== SPREADSHEETS ====================
# ID da Google Sheet para registos
# SPREADSHEET_ID=

# ==================== CLOUDFLARE ====================
# Account ID da Cloudflare (para Bulk Redirects API)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# API Token com permissões: Account > Bulk URL Redirects > Edit, Account > Account Filter Lists > Edit
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Nome da lista de redirects no Cloudflare (opcional, default: ameciclo-links-redirects)
# CLOUDFLARE_REDIRECT_LIST_NAME=ameciclo-links-redirects

# ==================== APP ====================
# URL base da aplicação
BASE_URL=https://your-app-url.com

# Domínio principal para os subdomínios de redirect (ex: ameciclo.org)
AMECICLO_DOMAIN=ameciclo.org

# ==================== ENVIRONMENT ====================
# Ambiente: development | production | test
NODE_ENV=development
